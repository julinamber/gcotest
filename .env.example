PORT=3000
JWT_SECRET=replace_with_strong_secret

# Must match the URL users type in the browser (used for OAuth redirects).
APP_BASE_URL=http://localhost:3000

# --- Recommended: XU Google Workspace sign-in (shows Google account picker) ---
# IT creates OAuth credentials once for the whole app; you do NOT need a personal Client ID per user.
#
# Summary: Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
#   Application type: Web application
#   Authorized JavaScript origins: http://localhost:3000  (and your production URL)
#   Authorized redirect URIs: http://localhost:3000/auth/google/callback  (same path on production)
# Then paste Client ID and Client secret below.
#
ENABLE_GOOGLE_OAUTH=true
GOOGLE_CLIENT_ID=823051603357-14j2n2knsqdaoiskivum43gs1j0a4aba.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
# Optional: restrict Google login hint to one Workspace domain, or disable hint:
#   unset = auto (students → my.xu.edu.ph, staff → xu.edu.ph)
#   GOOGLE_OAUTH_HOSTED_DOMAIN=my.xu.edu.ph   force one domain for everyone
#   GOOGLE_OAUTH_HOSTED_DOMAIN=             empty after = disables hosted-domain hint (account picker only)

# Primary fallback: email + password stored in this app (issued by GCO)
ALLOW_PASSWORD_LOGIN=true

SESSION_SECRET=replace_with_strong_session_secret
SESSION_COOKIE_NAME=gco.sid
SESSION_MAX_AGE_MS=604800000
SESSION_COOKIE_SECURE=false

ADMIN_EMAILS=admin@xu.edu.ph

DB_HOST=mysql
DB_PORT=3306
DB_USER=gco_user
DB_PASSWORD=gco_password
DB_NAME=gco_appointments

DB_CONNECT_RETRIES=20
DB_CONNECT_RETRY_DELAY_MS=3000

# --- Email notifications (separate from Google login) ---
# Signing in with Google does NOT send mail. The app sends mail when bookings change using SMTP below.
# The "to" address is each user's school email in the database (matches their XU account when they use Google login).
#
# Production — option A (typical for a department mailbox):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@xu.edu.ph
# Only these recipient domains will receive notification emails.
NOTIFICATION_ALLOWED_DOMAINS=my.xu.edu.ph,xu.edu.ph
# Optional (dev only): use MailHog instead of Gmail
# SMTP_HOST=mailhog
# SMTP_PORT=1025
# SMTP_SECURE=false

GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
